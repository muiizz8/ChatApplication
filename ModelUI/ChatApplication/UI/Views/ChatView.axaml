<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="640"
    x:Class="ChatApplication.UI.Views.ChatView">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header / Connection Controls ──────────────────────────── -->
        <Border Grid.Row="0"
                Classes="card"
                Margin="10,10,10,4"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                <!-- Left: Config + Status -->
                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">

                    <!-- Protocol -->
                    <StackPanel Spacing="4" Width="110" Margin="0,0,18,0">
                        <TextBlock Text="PROTOCOL"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding Protocols}"
                                  SelectedItem="{Binding SelectedProtocol}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="36"
                               Fill="{actipro:ThemeResource Container2BorderBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />

                    <!-- Instance -->
                    <StackPanel Spacing="4" Width="172" Margin="0,0,18,0">
                        <TextBlock Text="INSTANCE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding Instances}"
                                  SelectedItem="{Binding SelectedInstance}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="36"
                               Fill="{actipro:ThemeResource Container2BorderBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />

                    <!-- Status -->
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="STATUS"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8"
                                     Fill="#22C55E"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <!-- Right: Action buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Button Content="Start"
                            Classes="theme-solid accent"
                            Click="StartServer_Click" />
                    <Button Content="Stop"
                            Classes="theme-outline"
                            Click="StopServer_Click" />
                    <Button Content="Connect"
                            Classes="theme-solid accent"
                            IsVisible="{Binding IsTcp}"
                            Click="Connect_Click" />
                    <Button Content="Disconnect"
                            Classes="theme-outline"
                            IsVisible="{Binding IsTcp}"
                            Click="Disconnect_Click" />
                    <Button Content="Clear Chat"
                            Classes="theme-outline"
                            Click="ClearChat_Click" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Messages area ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScrollViewer"
                      Margin="10,4"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesItemsControl"
                          ItemsSource="{Binding Messages}"
                          Margin="0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6,3">

                            <!-- Received bubble -->
                            <Border HorizontalAlignment="Left"
                                    MaxWidth="560"
                                    IsVisible="{Binding IsReceived}"
                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4,16,16,16"
                                    Padding="14,10">
                                <StackPanel Spacing="4">

                                    <!-- Type badge (hidden for plain messages) -->
                                    <Border IsVisible="{Binding HasTypeLabel}"
                                            Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Opacity="0.75" />
                                    </Border>

                                    <TextBlock Text="{Binding Remote}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5" />

                                    <!-- Reply context -->
                                    <Border IsVisible="{Binding HasReplyContext}"
                                            Background="#10000000"
                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                            BorderThickness="2,0,0,0"
                                            CornerRadius="0,4,4,0"
                                            Padding="8,4"
                                            Margin="0,2,0,4">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="↩"
                                                       FontSize="11"
                                                       Opacity="0.55"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ReplyToText}"
                                                       FontSize="11"
                                                       Opacity="0.55"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="320"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20" />
                                    <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                               FontSize="10"
                                               Opacity="0.45"
                                               HorizontalAlignment="Right" />

                                    <!-- Yes/No response buttons for messages requiring responses -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                Margin="0,8,0,0"
                                                IsVisible="{Binding HasYesNoOptions}">
                                        <TextBlock FontSize="9"
                                                   Opacity="0.5"
                                                   Text="Response:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <Button Content="👍 Yes"
                                                Classes="theme-outline"
                                                Click="QuickYes_Click"
                                                Padding="8,4"
                                                FontSize="11"
                                                Tag="{Binding}" />
                                        <Button Content="👎 No"
                                                Classes="theme-outline"
                                                Click="QuickNo_Click"
                                                Padding="8,4"
                                                FontSize="11"
                                                Tag="{Binding}" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- Sent bubble -->
                            <Border HorizontalAlignment="Right"
                                    MaxWidth="560"
                                    IsVisible="{Binding IsSent}"
                                    Background="{DynamicResource ChatSentBubbleBrush}"
                                    CornerRadius="16,4,16,16"
                                    Padding="14,10">
                                <StackPanel Spacing="4">

                                    <!-- Type badge (hidden for plain messages) -->
                                    <Border IsVisible="{Binding HasTypeLabel}"
                                            Background="#20000000"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource ChatSentBubbleTextBrush}"
                                                   Opacity="0.85" />
                                    </Border>

                                    <!-- Reply context -->
                                    <Border IsVisible="{Binding HasReplyContext}"
                                            Background="#20000000"
                                            BorderBrush="#40FFFFFF"
                                            BorderThickness="2,0,0,0"
                                            CornerRadius="0,4,4,0"
                                            Padding="8,4"
                                            Margin="0,2,0,4">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="↩"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ChatSentBubbleTextBrush}"
                                                       Opacity="0.7"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ReplyToText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ChatSentBubbleTextBrush}"
                                                       Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="320"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20"
                                               Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="4">
                                        <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                                   FontSize="10"
                                                   Opacity="0.65"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                        <TextBlock Text="✓ Delivered"
                                                   FontSize="10"
                                                   Opacity="0.75"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsDelivered}"
                                                   Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Input Bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Classes="card"
                Margin="10,4,10,10"
                Padding="12,10">
            <Grid RowDefinitions="Auto,Auto">

                <!-- Row 0: Message Context (Auto-detected) + Options -->
                <Grid Grid.Row="0" ColumnDefinitions="1*,Auto" Margin="0,0,0,8">
                    <!-- Left: Message type indicator (info only, not a dropdown) -->
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock FontSize="9"
                                           FontWeight="SemiBold"
                                           Opacity="0.5"
                                           Text="TYPE:" />
                                <TextBlock x:Name="MessageTypeLabel"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="{Binding CurrentMessageTypeLabel}" />
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="10"
                                   Opacity="0.6"
                                   Text="{Binding ReplyContextLabel}"
                                   IsVisible="{Binding HasReplyContext}" />
                    </StackPanel>

                    <!-- Right: Requires Yes/No option -->
                    <CheckBox Grid.Column="1"
                              Content="Requires Yes/No"
                              IsChecked="{Binding RequiresYesNo}"
                              VerticalAlignment="Center"
                              Margin="0,0,0,0" />
                </Grid>

                <!-- Row 1: Text input + Send Button -->
                <Grid Grid.Row="1" ColumnDefinitions="*,10,Auto">
                    <TextBox Grid.Column="0"
                             x:Name="MessageInput"
                             Text="{Binding MessageText}"
                             Watermark="Type a message and press Enter to send…"
                             AcceptsReturn="False"
                             VerticalContentAlignment="Center"
                             KeyDown="MessageInput_KeyDown" />
                    <Button Grid.Column="2"
                            Content="Send"
                            Classes="theme-solid accent"
                            Width="84"
                            Click="Send_Click" />
                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
